{
    "name": "devianl2/laravel-scorm",
    "description": "PEOPLEAPS scorm package",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Devian Leong",
            "email": "devian@peoplelogy.com"
        },
        {
            "name": "Aydin Pramasta",
            "email": "aydin.ilham@sevima.id"
        }
    ],
    "require": {
        "php": "^8.3",
        "doctrine/common": "^3.5",
        "league/flysystem": "^3.30",
        "nesbot/carbon": "^3.10",
        "ext-zip": "*",
        "ext-dom": "*"
    },
    "autoload": {
        "psr-4": {
            "Peopleaps\\Scorm\\": "/src"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Peopleaps\\Scorm\\ScormServiceProvider"
            ],
            "aliases": {
                "ScormManager": "Peopleaps\\Scorm\\Facade\\ScormManager"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
